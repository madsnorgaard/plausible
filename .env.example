# Plausible Community Edition
PLAUSIBLE_VERSION=v2.1.4
PLAUSIBLE_DOMAIN=analytics.theazanianprepper.online

# Generate with: openssl rand -base64 48
SECRET_KEY_BASE=

# Strong random password for PostgreSQL
POSTGRES_PASSWORD=

# Generated in Plausible UI after first-time setup (Settings → API Keys)
# Must be set before plausible_exporter will work
PLAUSIBLE_API_KEY=

# Comma-separated list of site IDs registered in Plausible
PLAUSIBLE_SITE_IDS=fenixnordic.solutions,cosycreator.online,madsnorgaard.net,theazanianprepper.online,photo.madsnorgaard.net,saho.madsnorgaard.net,drupal.madsnorgaard.net
